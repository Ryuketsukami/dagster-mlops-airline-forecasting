# Use gh secret set -f .env to set these in GitHub Actions
# =============================================================================
# Google Cloud Platform
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west2
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# BigQuery
# =============================================================================
BIGQUERY_DATASET=demand_forecasting
BIGQUERY_LOCATION=EU

# =============================================================================
# Google Cloud Storage
# =============================================================================
GCS_BUCKET_NAME=your-bucket-name
GCS_BRONZE_PREFIX=bronze
GCS_SILVER_PREFIX=silver
GCS_GOLD_PREFIX=gold
GCS_MODELS_PREFIX=models
GCS_CHAMPION_PREFIX=champion
GCS_MONITORING_PREFIX=monitoring

# =============================================================================
# MLflow
# =============================================================================
MLFLOW_TRACKING_URI=https://your-mlflow-server.example.com
MLFLOW_EXPERIMENT_NAME=demand_forecasting
MLFLOW_MODEL_NAME=flight_demand_champion

# =============================================================================
# Dagster Cloud
# =============================================================================
DAGSTER_CLOUD_API_TOKEN=your-dagster-cloud-api-token
DAGSTER_CLOUD_URL=https://your-org.dagster.cloud
DAGSTER_HOME=/tmp/dagster_home

# =============================================================================
# FastAPI serving
# =============================================================================
SERVING_HOST=0.0.0.0
SERVING_PORT=8080

# =============================================================================
# DVC
# =============================================================================
DVC_REMOTE_URL=gs://your-bucket-name/dvc-cache
